# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================================
# WHATSAPP PROVIDERS
# ============================================================================

# Z-API
VITE_ZAPI_BASE_URL=https://api.z-api.io
VITE_ZAPI_INSTANCE_ID=your_instance_id
ZAPI_API_TOKEN=your_api_token

# Evolution
VITE_EVOLUTION_BASE_URL=https://api.evolution.com
EVOLUTION_API_KEY=your_api_key

# ============================================================================
# LLM PROVIDERS (AI)
# ============================================================================

# Groq
VITE_GROQ_API_KEY=your_groq_api_key
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI
VITE_OPENAI_API_KEY=your_openai_api_key
VITE_OPENAI_MODEL=gpt-4o-mini

# Google Gemini
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_MODEL=gemini-2.0-flash

# ============================================================================
# NOTIFICATION SERVICES
# ============================================================================

# Resend (Email)
VITE_RESEND_API_KEY=your_resend_api_key
VITE_RESEND_FROM_EMAIL=noreply@yourdomain.com

# Twilio (SMS)
VITE_TWILIO_ACCOUNT_SID=your_account_sid
VITE_TWILIO_AUTH_TOKEN=your_auth_token
VITE_TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# STORAGE
# ============================================================================

VITE_STORAGE_BUCKET=omni-flow-media
VITE_STORAGE_URL=https://your-project.supabase.co/storage/v1/object/public/omni-flow-media

# ============================================================================
# WEBHOOK CONFIGURATION
# ============================================================================

VITE_WEBHOOK_RECEIVER_URL=http://localhost:3000/functions/v1/webhook-receiver
VITE_WEBHOOK_SEND_WHATSAPP_URL=http://localhost:3000/functions/v1/send-whatsapp
VITE_WEBHOOK_AI_PROXY_URL=http://localhost:3000/functions/v1/ai-proxy

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

VITE_APP_ENV=development
VITE_APP_DEBUG=true

VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000

VITE_LOG_LEVEL=debug

# ============================================================================
# ANALYTICS (Opcional)
# ============================================================================

VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_API_KEY=your_analytics_key
